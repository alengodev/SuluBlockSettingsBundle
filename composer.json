{
    "name": "alengo/block-settings-bundle",
    "description": "Configurable block settings injection for Sulu CMS content blocks",
    "type": "symfony-bundle",
    "homepage": "https://github.com/alengodev/SuluBlockSettingsBundle",
    "license": "MIT",
    "authors": [
        {
            "name": "Alexander Huber-De Monte"
        }
    ],
    "support": {
        "issues": "https://github.com/alengodev/SuluBlockSettingsBundle/issues",
        "source": "https://github.com/alengodev/SuluBlockSettingsBundle"
    },
    "require": {
        "php": "^8.2",
        "sulu/sulu": "^3.0",
        "symfony/dependency-injection": "^7.0",
        "symfony/framework-bundle": "^7.0",
        "symfony/http-kernel": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Alengo\\SuluBlockSettingsBundle\\": "src/"
        }
    },
    "extra": {
        "symfony": {
            "require": "^7.0"
        }
    }
}
